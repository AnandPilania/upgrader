{
    "name": "anandpilania/upgrader",
    "description": "Modular upgrade tool for Laravel, PHP, React, Vue, Tailwind, TypeScript, and JavaScript",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Anand Pilania",
            "email": "pilaniaanand@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "symfony/console": "^7.0",
        "symfony/process": "^7.0",
        "symfony/yaml": "^7.0",
        "symfony/finder": "^7.0",
        "nikic/php-parser": "^5.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "autoload": {
        "psr-4": {
            "Upgrader\\": "src/",
            "Upgrader\\Modules\\PHP\\": "modules/php/src/",
            "Upgrader\\Modules\\Laravel\\": "modules/laravel/src/",
            "Upgrader\\Modules\\ReactJS\\": "modules/reactjs/src/",
            "Upgrader\\Modules\\VueJS\\": "modules/vuejs/src/",
            "Upgrader\\Modules\\TailwindCSS\\": "modules/tailwindcss/src/",
            "Upgrader\\Modules\\TypeScript\\": "modules/typescript/src/",
            "Upgrader\\Modules\\JavaScript\\": "modules/javascript/src/"
        }
    },
    "bin": [
        "bin/upgrader"
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
